FROM rust:latest AS builder
WORKDIR /app
COPY . .
RUN cargo build --release
RUN strip target/release/onwards

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*
COPY --from=builder /app/target/release/onwards /usr/local/bin/onwards

# Create default config directory
RUN mkdir -p /etc/onwards

# Entrypoint supports config file via env vars
ENTRYPOINT ["sh", "-c", "onwards --targets /etc/onwards/config.yaml $ONWARDS_ARGS"]